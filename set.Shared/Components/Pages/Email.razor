@page "/email"
@using MimeKit
@using System.Threading
@using Microsoft.Extensions.Localization
@using System.Globalization
@using Models
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@implements IDisposable
@inject TranslationService TranslationService
@inject TaskService TaskService
@inject IStringLocalizerFactory LocalizerFactory
@inject LanguageService LangService

@if (L != null)
{
    <h1>@L["EmailTitle"]</h1>

    <div class="mb-3">
        <label for="emailInput" class="form-label">@L["LabelEmail"]</label>
        <input type="email" class="form-control" id="emailInput" placeholder="@L["PlaceholderEmail"]" @bind="email">
        <input type="password" class="form-control mt-2" id="passwordInput" placeholder="@L["PlaceholderPassword"]" @bind="password">
        <button class="btn btn-primary mt-2" @onclick="StartService" disabled="@isListening">
            @(isListening ? L["BtnListening"] : L["BtnRegister"])
        </button>
    </div>

    <h3>@L["ReceivedEmails"] (@emails.Count)</h3>
    <ul class="list-group">
        @foreach (var mail in emails)
        {
            <li class="list-group-item">
                <strong>From:</strong> @mail.From <br />
                <strong>Subject:</strong> @mail.Subject <br />
                <small class="text-muted">@mail.Date.ToString("HH:mm:ss")</small>
            </li>
        }
        @if (emails.Count == 0)
        {
            <li class="list-group-item text-center">@L["NoEmails"]</li>
        }
    </ul>

    <div class="mb-3 mt-4">
        <label for="nlpInput" class="form-label">@L["LabelNLP"]</label>
        <input type="text" class="form-control" id="nlpInput" placeholder="@L["LabelNLP"]" @bind="Text">
        <button class="btn btn-secondary mt-2" @onclick="() => NLP(Text)" disabled="@string.IsNullOrEmpty(Text)">
            @L["BtnProcess"]
        </button>
        <ul class="list-group mt-3">
            @if (tasks != null)
            {
                @foreach (var taskText in tasks)
                {
                    <li class="list-group-item">
                        <strong>@L["TaskPrefix"]:</strong> @taskText.ToString() <br />
                        <small class="text-muted">@L["TaskStatus"]</small>
                    </li>
                }
            }
        </ul>
    </div>  
}

@code {
    private IStringLocalizer? L;
    private string? email;
    private string? password;
    private bool isListening = false;
    private List<MimeMessage> emails = new List<MimeMessage>();
    private CancellationTokenSource cts = new CancellationTokenSource();

    private string Text = string.Empty;
    private List<dynamic> tasks = new List<dynamic>();
    private EmailListener? listener; 
    private string? enText;          

    protected override void OnInitialized()
    {
        // אתחול הלוקלייזר
        L = LocalizerFactory.Create("Resources.AppResources", "set.Shared");
        
        // הרשמה לאירוע שינוי שפה
        LangService.OnLanguageChanged += HandleLanguageChanged;
    }

    private void HandleLanguageChanged()
    {
        // רענון הלוקלייזר כשהשפה משתנה
        L = LocalizerFactory.Create("Resources.AppResources", "set.Shared");
        InvokeAsync(StateHasChanged);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            email = await LocalStorage.GetItemAsync<string>("userEmail") ?? string.Empty;
            password = await LocalStorage.GetItemAsync<string>("userPassword") ?? string.Empty;
            StateHasChanged();
        }
    }

    private async Task StartService()
    {
        if (string.IsNullOrEmpty(email) || string.IsNullOrEmpty(password)) return;

        await LocalStorage.SetItemAsync("userEmail", email);
        await LocalStorage.SetItemAsync("userPassword", password);

        isListening = true;
        listener = new EmailListener(email, password);

        listener.OnNewEmailReceived += async (message) =>
        {
            await InvokeAsync(() =>
            {
                emails.Insert(0, message);
                StateHasChanged();
            });
        };

        _ = Task.Run(() => listener.StartListeningAsync(cts.Token));
    }

    private async Task NLP(string text)
    {
        if (string.IsNullOrEmpty(text)) return;

        enText = await TranslationService.TranslateToEnglishAsync(text);
        var extractor = new Models.TaskExtractor();
        var extractedStrings = extractor.ExtractTasks(enText ?? string.Empty);

        foreach (var taskText in extractedStrings)
        {
            TaskService.AddTask(taskText.Description ?? string.Empty, enText ?? string.Empty, taskText.TaskTime); 
        }

        tasks = extractedStrings.Cast<dynamic>().ToList(); 
        StateHasChanged();
    }
    private string? translationResult;

    private async Task TestTranslation()
    {
        translationResult = await TranslationService.TranslateToEnglishAsync(Text);
        StateHasChanged();
    }

    public void Dispose()
    {
        cts.Cancel();
        cts.Dispose();
        // חשוב: הסרת ההרשמה כדי למנוע בעיות זיכרון
        LangService.OnLanguageChanged -= HandleLanguageChanged;
    }
}