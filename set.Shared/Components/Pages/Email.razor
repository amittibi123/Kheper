@page "/email"
@using MimeKit
@using System.Threading
@using Models
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@implements IDisposable
@inject TranslationService TranslationService
@inject TaskService TaskService

<h1>Email Registration Page</h1>

<div class="mb-3">
    <label for="emailInput" class="form-label">Email address</label>
    <input type="email" class="form-control" id="emailInput" placeholder="enter your email" @bind="email">
    <input type="password" class="form-control mt-2" id="passwordInput" placeholder="enter your password" @bind="password">
    <button class="btn btn-primary mt-2" @onclick="StartService" disabled="@isListening">
        @(isListening ? "Listening..." : "Register & Start")
    </button>
</div>

<h3>Received Emails (@emails.Count)</h3>
<ul class="list-group">
    @foreach (var mail in emails)
    {
        <li class="list-group-item">
            <strong>From:</strong> @mail.From <br />
            <strong>Subject:</strong> @mail.Subject <br />
            <small class="text-muted">@mail.Date.ToString("HH:mm:ss")</small>
        </li>
    }
    @if (emails.Count == 0)
    {
        <li class="list-group-item text-center">No emails received yet.</li>
    }
</ul>

<div class="mb-3">
    <label for="nlpInput" class="form-label">NLP Input</label>
    <input type="text" class="form-control" id="nlpInput" placeholder="enter text for NLP processing" @bind="Text">
    <button class="btn btn-secondary mt-2" @onclick="() => NLP(Text)" disabled="@string.IsNullOrEmpty(Text)">
        Process with NLP
    </button>
    <ul class="list-group mt-3">
        @if (tasks != null)
        {
            @foreach (var taskText in tasks)
            {
                <li class="list-group-item">
                    <strong>משימה:</strong> @taskText.ToString() <br />
                    <small class="text-muted">סטטוס: בטיפול</small>
                </li>
            }
        }
    </ul>
</div>

@code {
    private string? email;
    private string? password;
    private bool isListening = false;
    private List<MimeMessage> emails = new List<MimeMessage>();
    private CancellationTokenSource cts = new CancellationTokenSource();

    private string Text = string.Empty;
    // בהנחה ש-ExtractTasks מחזירה רשימה של אובייקטים עם Name ו-Description
    private List<dynamic> tasks = new List<dynamic>();
    
    private EmailListener? listener; // הגדרת המאזין למייל
    private string? enText;          // הגדרת משתנה לטקסט המתורגם
    protected override async Task OnInitializedAsync()
    {
        email = await LocalStorage.GetItemAsync<string>("userEmail") ?? string.Empty;
        password = await LocalStorage.GetItemAsync<string>("userPassword") ?? string.Empty;
    }

    private async Task StartService()
    {
        if (string.IsNullOrEmpty(email) || string.IsNullOrEmpty(password)) return;

        await LocalStorage.SetItemAsync("userEmail", email);
        await LocalStorage.SetItemAsync("userPassword", password);

        isListening = true;

        
        listener = new EmailListener(email, password);

        listener.OnNewEmailReceived += async (message) =>
        {
            await InvokeAsync(() =>
            {
                emails.Insert(0, message);
                StateHasChanged();
            });
        };

        _ = Task.Run(() => listener.StartListeningAsync(cts.Token));
    }

    private async Task NLP(string text)
    {
        if (string.IsNullOrEmpty(text)) return;

        enText = await TranslationService.TranslateToEnglishAsync(text);
        var extractor = new Models.TaskExtractor();
        
        // כאן התיקון: extractor.ExtractTasks מחזיר List<string>
        var extractedStrings = extractor.ExtractTasks(enText ?? string.Empty);

        foreach (var taskText in extractedStrings)
        {
            // אנחנו שולחים את הטקסט בתור שם המשימה, ותיאור ריק
            TaskService.AddTask(taskText, enText ?? string.Empty); 
        }

        // עדכון הרשימה המקומית לתצוגה בדף האימייל (אם תרצה)
        tasks = extractedStrings.Cast<dynamic>().ToList(); 
        
        StateHasChanged();
    }

    public void Dispose()
    {
        cts.Cancel();
        cts.Dispose();
    }
}