@page "/settings/Account"
@using System.Net.Http
@using System.Net.Http.Json
@inject IHttpClientFactory ClientFactory
@inject NavigationManager NavManager
@inject NavigationState NavState 
@implements IDisposable
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage

<h1>Account Settings</h1>

<div class="login-container">
    @* הוספת כותרת קטנה כדי להבין מה קורה *@
    <h3>Login or Register</h3>
    
    <input @bind="username" placeholder="Username" class="form-control mb-2" />
    <input @bind="password" type="password" placeholder="Password" class="form-control mb-2" />
    
    <div class="button-group">
        <button class="btn btn-primary" @onclick="HandleLogin">Login</button>
        <button class="btn btn-secondary" @onclick="HandleRegister">Register</button>
    </div>

    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <p class="mt-3" style="color: @(statusMessage.Contains("בהצלחה") ? "green" : "red")">
            @statusMessage
        </p>
    }
</div>

@code {
    public class TodoTask
    {
        public string Task { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;

        public DateTime CreatedAt { get; set; }

        public DateTime? DueDate { get; set; }

        public TodoTask() {CreatedAt = DateTime.Now; }
    }

    private List<TodoTask> tasks = new();
    private string username = string.Empty;
    private string password = string.Empty;
    private string statusMessage = string.Empty;

    private string? email;
    private string? emailPassword;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            email = await LocalStorage.GetItemAsync<string>("userEmail") ?? string.Empty;
            emailPassword = await LocalStorage.GetItemAsync<string>("userPassword") ?? string.Empty;
            var savedTasks = await LocalStorage.GetItemAsync<List<TodoTask>>("tasks");
            if (savedTasks != null)
            {
                tasks = savedTasks;
                StateHasChanged(); 
            }
            StateHasChanged();
        }
    }

    
    private async Task HandleLogin()
    {
        await SendRequest("api/AccountAPI/login", "התחברת בהצלחה!");
    }

    // פונקציית הרשמה
    private async Task HandleRegister()
    {
        await SendRequest("api/AccountAPI/register", "נרשמת בהצלחה! עכשיו אפשר להתחבר.");
    }

    private async Task SendRequest(string endpoint, string successText)
    {
        try
        {
            statusMessage = "שולח בקשה...";
            var client = ClientFactory.CreateClient("LocalApi");
            var loginData = new { Username = username, Password = password, Email = email, EmailPassword = emailPassword, tasks = tasks };

            var response = await client.PostAsJsonAsync(endpoint, loginData);

            if (response.IsSuccessStatusCode)
            {
                statusMessage = successText;

                // אם זו התחברות, אנחנו רוצים לקרוא את הנתונים שהשרת שלח חזרה
                if (endpoint.Contains("login"))
                {
                    var result = await response.Content.ReadFromJsonAsync<LoginResponse>();
                    if (result != null)
                    {
                        // שמירת הנתונים שהגיעו מה-DB לתוך ה-LocalStorage
                        if (!string.IsNullOrEmpty(result.Email))
                        {
                            await LocalStorage.SetItemAsync("userEmail", result.Email);
                            email = result.Email; // עדכון המשתנה המקומי
                        }
                        if (!string.IsNullOrEmpty(result.EmailPassword))
                        {
                            await LocalStorage.SetItemAsync("userPassword", result.EmailPassword);
                            emailPassword = result.EmailPassword; // עדכון המשתנה המקומי
                        }
                        if (result.Tasks != null)
                        {
                            tasks = result.Tasks;
                            await LocalStorage.SetItemAsync("tasks", tasks);
                        }
                    }
                }
            }
            else
            {
                // במקום ReadFromJsonAsync, נקרא את זה כטקסט חופשי
                var errorRaw = await response.Content.ReadAsStringAsync();
                
                // ננסה להציג הודעה ידידותית
                if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
                {
                    statusMessage = "שם משתמש או סיסמה שגויים (או שהמשתמש לא קיים).";
                }
                else
                {
                    statusMessage = $"שגיאה מהשרת: {errorRaw}";
                }
            }
        }
        catch (Exception ex)
        {
            statusMessage = $"שגיאת תקשורת: {ex.Message}";
        }
    }

    // מחלקה פנימית לקבלת התשובה מהשרת
    public class LoginResponse
    {
        public string? Message { get; set; }
        public int UserId { get; set; }
        public string? Email { get; set; }
        public string? EmailPassword { get; set; }

        public List<TodoTask>? Tasks { get; set; }
    }

    public void Dispose()
    {
        if (!NavManager.Uri.Contains("settings", StringComparison.OrdinalIgnoreCase))
        {
            NavState.SetSettingsMode(false);
        }
    }
}