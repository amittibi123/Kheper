@page "/settings/GeneralSettings"
@inject IJSRuntime JSRuntime
@implements IDisposable
@inject NavigationManager NavManager
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@using Microsoft.Extensions.Localization
@using System.Threading.Tasks
@inject LanguageService LangService
@inject IStringLocalizerFactory LocalizerFactory
@inject NavigationState NavState

@if (L != null)
{
    <h1>@L["Settings"]</h1>
    <p>@L["ToggleDarkMode"]</p>
    
    <label class="switch">
        <input type="checkbox" @bind="isDarkMode" @bind:after="OnThemeChanged">
        <span class="slider">
            <span class="knob">
                @(isDarkMode ? "🌙" : "☀️")
            </span>
        </span>
    </label>

    <div class="card p-3 shadow-sm" style="margin-top: 50px;">
        <label for="langSelect" class="form-label fw-bold">@L["SelectLanguage"]</label>
        <select id="langSelect" class="form-select" @onchange="OnLanguageSelected">
            <option value="en-US" selected="@(LangService.GetCurrentLanguage() == "en-US")">English</option>
            <option value="he-IL" selected="@(LangService.GetCurrentLanguage() == "he-IL")">עברית</option>
        </select>
    </div>
}

@code {
    private IStringLocalizer? L;
    private bool isDarkMode;
    private string currentLanguage = "en-US";

    protected override void OnInitialized()
    {
        NavState.SetSettingsMode(true);
        
        L = LocalizerFactory.Create("Resources.AppResources", "set.Shared");
        
        
        LangService.OnLanguageChanged += HandleLanguageChanged;
    }

    private void HandleLanguageChanged()
    {
        L = LocalizerFactory.Create("Resources.AppResources", "set.Shared");
        StateHasChanged();
    }

    private async Task OnThemeChanged()
    {
        await JSRuntime.InvokeVoidAsync("themeToggle.setTheme", isDarkMode);
        await LocalStorage.SetItemAsync("isDarkMode", isDarkMode);
    }

    private async Task OnLanguageSelected(ChangeEventArgs e)
    {
        string? selectedLanguage = e.Value?.ToString();
        if (!string.IsNullOrEmpty(selectedLanguage))
        {
            LangService.SetLanguage(selectedLanguage);
            currentLanguage = selectedLanguage;
            await LocalStorage.SetItemAsync("selectedLanguage", selectedLanguage);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try 
            {
                await JSRuntime.InvokeVoidAsync("import", "./_content/set.Shared/ThemeToggle.js");

                var savedTheme = await LocalStorage.GetItemAsync<bool?>("isDarkMode");
                if (savedTheme.HasValue)
                {
                    isDarkMode = savedTheme.Value;
                }
                else
                {
                    isDarkMode = await JSRuntime.InvokeAsync<bool>("eval", "window.matchMedia('(prefers-color-scheme: dark)').matches");
                }

                await JSRuntime.InvokeVoidAsync("themeToggle.setTheme", isDarkMode);
                
                
                var savedLang = await LocalStorage.GetItemAsync<string>("selectedLanguage");
                if (!string.IsNullOrEmpty(savedLang))
                {
                    currentLanguage = savedLang;
                    
                    
                }
                
                StateHasChanged(); 
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error loading settings: {ex.Message}");
            }
        }
    }

    public void Dispose()
    {
        LangService.OnLanguageChanged -= HandleLanguageChanged;

        // בדיקה: אם הכתובת החדשה לא מכילה את המילה settings, רק אז נכבה את מצב ההגדרות
        if (!NavManager.Uri.Contains("settings", StringComparison.OrdinalIgnoreCase))
        {
            NavState.SetSettingsMode(false);
        }
    }
}