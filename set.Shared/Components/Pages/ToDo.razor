@page "/todo"
@using System.Threading.Tasks
@using Microsoft.Extensions.Localization
@using System.Globalization
@inject IStringLocalizerFactory LocalizerFactory
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@implements IDisposable
@inject TaskService TaskService
@inject LanguageService LangService

@* בדיקה שהלוקלייזר מוכן לפני הציור *@
@if (L != null)
{
    <h1>@L["TodoTitle"]</h1>

    <div class="mb-3 p-3 border rounded bg-light">

        <input type="text"
            class="form-control mb-2"
            placeholder="@L["PlaceholderTask"]"
            @bind="newTask">

        <input type="text"
            class="form-control mb-2"
            placeholder="@L["PlaceholderDesc"]"
            @bind="taskDescription">

        <!-- Date & Time -->
        <InputDate class="form-control mb-2"
                @bind-Value="scheduledAt"
                Type="InputDateType.DateTimeLocal" />

        <button class="btn btn-primary w-100"
                @onclick="AddTask">
            @L["AddBtn"]
        </button>

    </div>

    <ul class="list-group">
        @foreach (var item in tasks)
        {
            <li class="list-group-item d-flex justify-content-between align-items-center">
                <div>
                    <strong>@item.Task</strong>: @item.Description

                    @if (item.DueDate != null)
                    {
                        <div class="text-muted small">
                            📅 @item.DueDate.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                        </div>
                    }
                </div>
                <button class="btn btn-sm btn-danger" @onclick="() => RemoveTask(item)">@L["DeleteBtn"]</button>
            </li>
        }
    </ul>

    <button class="btn btn-warning mt-2" @onclick="ClearTasks">@L["ClearAllBtn"]</button>

}

@code {
    private IStringLocalizer? L;

    public class TodoTask
    {
        public string Task { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;

        public DateTime CreatedAt { get; set; }

        public DateTime? DueDate { get; set; }

        public TodoTask() {CreatedAt = DateTime.Now; }
    }

    private string? newTask;
    private string? taskDescription;

    private DateTime? scheduledAt;
    private List<TodoTask> tasks = new();

    protected override void OnInitialized()
    {
        
        L = LocalizerFactory.Create("Resources.AppResources", "set.Shared");

        
        LangService.OnLanguageChanged += HandleLanguageChanged;
        
        TaskService.OnTaskAdded += HandleTaskAdded;
    }

    protected override async Task OnInitializedAsync()
    {
        tasks = new List<TodoTask>();
        await SyncTasksFromService();
    }

    private void ChangeLanguage(string cultureCode)
    {
        var culture = new CultureInfo(cultureCode);
        CultureInfo.DefaultThreadCurrentCulture = culture;
        CultureInfo.DefaultThreadCurrentUICulture = culture;
        
        
        L = LocalizerFactory.Create("Resources.AppResources", "set.Shared");
        
        StateHasChanged(); 
    }

    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var savedTasks = await LocalStorage.GetItemAsync<List<TodoTask>>("tasks");
            if (savedTasks != null)
            {
                tasks = savedTasks;
                StateHasChanged(); 
            }
        }
    }

    private async void HandleTaskAdded() => await SyncTasksFromService();

    private async Task SyncTasksFromService()
    {
        if (TaskService.AllTasks.Any())
        {
            await InvokeAsync(async () =>
            {
                foreach (var t in TaskService.AllTasks.ToList())
                {
                    await AddTask(t.Name, t.Desc);
                }
                TaskService.AllTasks.Clear();
                StateHasChanged();
            });
        }
    }

    private async Task AddTask()
    {
        if (!string.IsNullOrWhiteSpace(newTask))
        {
            await AddTask(newTask, taskDescription ?? string.Empty, scheduledAt);
            newTask = string.Empty;
            taskDescription = string.Empty;
            scheduledAt = null;
        }
    }

    public async Task AddTask(string taskName, string description, DateTime? dueDate = null)
    {
        if (!string.IsNullOrWhiteSpace(taskName))
        {
            tasks.Add(new TodoTask { Task = taskName, Description = description, DueDate = dueDate });
            await LocalStorage.SetItemAsync("tasks", tasks);
        }
    }

    private async Task RemoveTask(TodoTask taskToRemove)
    {
        tasks.Remove(taskToRemove);
        await LocalStorage.SetItemAsync("tasks", tasks);
    }

    private async Task ClearTasks()
    {
        tasks.Clear();
        await LocalStorage.SetItemAsync("tasks", tasks);
    }

    private void HandleLanguageChanged()
    {
        
        L = LocalizerFactory.Create("Resources.AppResources", "set.Shared");
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        
        LangService.OnLanguageChanged -= HandleLanguageChanged;
        TaskService.OnTaskAdded -= HandleTaskAdded;
    }
}