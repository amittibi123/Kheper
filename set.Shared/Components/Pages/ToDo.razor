@page "/todo"
@using System.Threading.Tasks
@using Microsoft.Extensions.Localization
@using System.Globalization
@using Models
@inject IStringLocalizerFactory LocalizerFactory
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@implements IDisposable
@inject TaskService TaskService
@inject LanguageService LangService

@if (L != null)
{
    <h1>@L["TodoTitle"]</h1>

    <!-- Breadcrumb Navigation -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb bg-light p-2 rounded">
            @foreach (var crumb in GetBreadcrumbs())
            {
                @if (crumb.Path == currentPath)
                {
                    <li class="breadcrumb-item active">@crumb.Name</li>
                }
                else
                {
                    <li class="breadcrumb-item">
                        <a href="#" @onclick="() => NavigateTo(crumb.Path)" @onclick:preventDefault>@crumb.Name</a>
                    </li>
                }
            }
        </ol>
    </nav>

    <!-- Create New Package (Folder) -->
    <div class="mb-3 p-3 border rounded bg-white">
        <h6 class="text-muted">📦 New Package (Folder)</h6>
        <div class="input-group">
            <input type="text"
                   class="form-control"
                   placeholder="Package name..."
                   @bind="newPackageName" />
            <button class="btn btn-outline-secondary" @onclick="AddPackage">
                ➕ Create Folder
            </button>
        </div>
    </div>

    <!-- Add Task Form -->
    <div class="mb-3 p-3 border rounded bg-light">
        <h6 class="text-muted">📝 New Task in: <strong>@currentPath</strong></h6>

        <input type="text"
               class="form-control mb-2"
               placeholder="@L["PlaceholderTask"]"
               @bind="newTask" />

        <input type="text"
               class="form-control mb-2"
               placeholder="@L["PlaceholderDesc"]"
               @bind="taskDescription" />

        <InputDate class="form-control mb-2"
                   @bind-Value="scheduledAt"
                   Type="InputDateType.DateTimeLocal" />

        <button class="btn btn-primary w-100" @onclick="AddTask">
            @L["AddBtn"]
        </button>
    </div>

    <!-- Subfolders (Packages) -->
    @if (CurrentPackages.Any())
    {
        <h6 class="text-muted mt-3">📁 Folders</h6>
        <ul class="list-group mb-3">
            @foreach (var pkg in CurrentPackages)
            {
                <li class="list-group-item d-flex justify-content-between align-items-center"
                    style="cursor:pointer;">
                    <span @onclick="() => NavigateTo(pkg.Path)">
                        📦 <strong>@pkg.Name</strong>
                        <span class="badge bg-secondary ms-2">
                            @TaskCountInPath(pkg.Path) tasks
                        </span>
                    </span>
                    <button class="btn btn-sm btn-outline-danger"
                            @onclick="() => RemovePackage(pkg)"
                            title="Delete folder and all contents">
                        🗑
                    </button>
                </li>
            }
        </ul>
    }

    <!-- Tasks at Current Level -->
    @if (CurrentTasks.Any())
    {
        <h6 class="text-muted">✅ Tasks</h6>
        <ul class="list-group mb-3">
            @foreach (var item in CurrentTasks)
            {
                <li class="list-group-item d-flex justify-content-between align-items-start">
                    <div>
                        <strong>@item.Task</strong>
                        @if (!string.IsNullOrWhiteSpace(item.Description))
                        {
                            <span>: @item.Description</span>
                        }
                        @if (item.DueDate != null)
                        {
                            <div class="text-muted small">
                                📅 @item.DueDate.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                            </div>
                        }
                        <div class="text-muted small">
                            🕐 Created: @item.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                        </div>
                    </div>
                    <button class="btn btn-sm btn-danger ms-2"
                            @onclick="() => RemoveTask(item)">
                        @L["DeleteBtn"]
                    </button>
                </li>
            }
        </ul>
    }

    @if (!CurrentPackages.Any() && !CurrentTasks.Any())
    {
        <div class="text-center text-muted p-4 border rounded">
            <p>📭 This folder is empty.</p>
            <p class="small">Create a sub-folder or add a task above.</p>
        </div>
    }

    <!-- Footer Actions -->
    <div class="d-flex gap-2 mt-2">
        @if (currentPath != "/")
        {
            <button class="btn btn-outline-secondary" @onclick="GoUp">
                ⬆ Up
            </button>
        }
        <button class="btn btn-warning" @onclick="ClearTasks">
            @L["ClearAllBtn"] (this folder)
        </button>
    </div>
}

@code {
    private IStringLocalizer? L;

    // ─── Models ────────────────────────────────────────────────

    public class TodoTask
    {
        public string Task { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public DateTime CreatedAt { get; set; }
        public DateTime? DueDate { get; set; }
        public string Path { get; set; } = "/";

        public TodoTask() { CreatedAt = DateTime.Now; }
    }

    public class Package
    {
        public string Name { get; set; } = string.Empty;
        public string Path { get; set; } = "/";
        public string ParentPath { get; set; } = "/";
    }

    // ─── State ─────────────────────────────────────────────────

    private string? newTask;
    private string? taskDescription;
    private string? newPackageName;
    private DateTime? scheduledAt;
    private string currentPath = "/";

    private List<TodoTask> tasks = new();
    private List<Package> packages = new();

    // ─── Computed ──────────────────────────────────────────────

    private IEnumerable<Package> CurrentPackages =>
        packages.Where(p => p.ParentPath == currentPath);

    private IEnumerable<TodoTask> CurrentTasks =>
        tasks.Where(t => t.Path == currentPath);

    /// Count tasks in a given path AND all its sub-paths
    private int TaskCountInPath(string path) =>
        tasks.Count(t => t.Path == path || t.Path.StartsWith(path.TrimEnd('/') + "/"));

    private List<(string Name, string Path)> GetBreadcrumbs()
    {
        var crumbs = new List<(string, string)> { ("🏠 Root", "/") };
        if (currentPath == "/") return crumbs;

        var parts = currentPath.Trim('/').Split('/');
        var built = "";
        foreach (var part in parts)
        {
            built += "/" + part;
            crumbs.Add((part, built));
        }
        return crumbs;
    }

    // ─── Navigation ────────────────────────────────────────────

    private void NavigateTo(string path)
    {
        currentPath = path;
        StateHasChanged();
    }

    private void GoUp()
    {
        if (currentPath == "/") return;
        var parts = currentPath.TrimEnd('/').Split('/');
        var parent = string.Join("/", parts.SkipLast(1));
        currentPath = string.IsNullOrEmpty(parent) ? "/" : parent;
        StateHasChanged();
    }

    // ─── Package Actions ───────────────────────────────────────

    private async Task AddPackage()
    {
        if (string.IsNullOrWhiteSpace(newPackageName)) return;

        var safeName = newPackageName.Trim().Replace("/", "-");
        var fullPath = currentPath.TrimEnd('/') + "/" + safeName;

        // Prevent duplicates
        if (packages.Any(p => p.Path == fullPath)) return;

        packages.Add(new Package
        {
            Name = safeName,
            Path = fullPath,
            ParentPath = currentPath
        });

        newPackageName = string.Empty;
        await LocalStorage.SetItemAsync("packages", packages);
    }

    private async Task RemovePackage(Package pkg)
    {
        // Remove all sub-packages recursively
        var toRemove = packages
            .Where(p => p.Path == pkg.Path || p.Path.StartsWith(pkg.Path.TrimEnd('/') + "/"))
            .ToList();
        foreach (var p in toRemove) packages.Remove(p);

        // Remove all tasks in those paths
        tasks.RemoveAll(t =>
            t.Path == pkg.Path ||
            t.Path.StartsWith(pkg.Path.TrimEnd('/') + "/"));

        await LocalStorage.SetItemAsync("packages", packages);
        await LocalStorage.SetItemAsync("tasks", tasks);
    }

    // ─── Task Actions ──────────────────────────────────────────

    private async Task AddTask()
    {
        if (!string.IsNullOrWhiteSpace(newTask))
        {
            await AddTask(newTask, taskDescription ?? string.Empty, scheduledAt);
            newTask = string.Empty;
            taskDescription = string.Empty;
            scheduledAt = null;
        }
    }

    public async Task AddTask(string taskName, string description, DateTime? dueDate = null)
    {
        if (!string.IsNullOrWhiteSpace(taskName))
        {
            tasks.Add(new TodoTask
            {
                Task = taskName,
                Description = description,
                DueDate = dueDate,
                Path = currentPath
            });
            await LocalStorage.SetItemAsync("tasks", tasks);
        }
    }

    private async Task RemoveTask(TodoTask taskToRemove)
    {
        tasks.Remove(taskToRemove);
        await LocalStorage.SetItemAsync("tasks", tasks);
    }

    private async Task ClearTasks()
    {
        tasks.RemoveAll(t => t.Path == currentPath);
        await LocalStorage.SetItemAsync("tasks", tasks);
    }

    // ─── Lifecycle ─────────────────────────────────────────────

    protected override void OnInitialized()
    {
        L = LocalizerFactory.Create("Resources.AppResources", "set.Shared");
        LangService.OnLanguageChanged += HandleLanguageChanged;
        TaskService.OnTaskAdded += HandleTaskAdded;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var savedTasks = await LocalStorage.GetItemAsync<List<TodoTask>>("tasks");
            if (savedTasks != null) tasks = savedTasks;

            var savedPackages = await LocalStorage.GetItemAsync<List<Package>>("packages");
            if (savedPackages != null) packages = savedPackages;

            StateHasChanged();
            await SyncTasksFromService();
        }
    }

    private async void HandleTaskAdded() => await SyncTasksFromService();

    private async Task SyncTasksFromService()
    {
        if (TaskService.AllTasks.Any())
        {
            await InvokeAsync(async () =>
            {
                foreach (var t in TaskService.AllTasks.ToList())
                {
                    await AddTask(t.Name, t.Desc, t.TaskTime);
                }
                TaskService.AllTasks.Clear();
                StateHasChanged();
            });
        }
    }

    private void HandleLanguageChanged()
    {
        L = LocalizerFactory.Create("Resources.AppResources", "set.Shared");
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        LangService.OnLanguageChanged -= HandleLanguageChanged;
        TaskService.OnTaskAdded -= HandleTaskAdded;
    }
}
