@page "/settings/Account"
@using System.Net.Http
@using System.Net.Http.Json
@using Models
@inject IHttpClientFactory ClientFactory
@inject NavigationManager NavManager
@inject NavigationState NavState 
@implements IDisposable
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@using Models
@inject LanguageService LangService
@using Microsoft.Extensions.Localization
@inject IStringLocalizerFactory LocalizerFactory

@if (L != null)
{
    <h1>@L["AccountSettings"]</h1>

    <div class="login-container">
        <h3>@L["LoginorRegister"]</h3>

        <input @bind="username" placeholder="@L["placeholderUsername"]" class="form-control mb-2"/>
        <input @bind="password" type="password" placeholder="@L["PlaceholderPassword"]" class="form-control mb-2"/>

        <div class="button-group">
            <button class="btn btn-primary" @onclick="HandleLogin">@L["Login"]</button>
            <button class="btn btn-secondary" @onclick="HandleRegister">@L["Register"]</button>
        </div>

        @if (!string.IsNullOrEmpty(statusMessage))
        {
            <p class="mt-3" style="color: @(statusMessage.Contains(@L["success"]) ? "green" : "red")">
                @statusMessage
            </p>
        }
    </div>
}

@code {
    public class TodoTask
    {
        public string Task { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public DateTime CreatedAt { get; set; }
        public DateTime? DueDate { get; set; }
        public string Path { get; set; } = "/";
        public TodoTask() { CreatedAt = DateTime.Now; }
    }

    public class Package
    {
        public string Name { get; set; } = string.Empty;
        public string Path { get; set; } = "/";
        public string ParentPath { get; set; } = "/";
    }

    private List<TodoTask> tasks = new();
    private List<Package> packages = new();   // ← added

    private string username = string.Empty;
    private string password = string.Empty;
    private string statusMessage = string.Empty;
    private string? email;
    private string? emailPassword;
    
    private IStringLocalizer? L;

    protected override void OnInitialized()
    {
        L = LocalizerFactory.Create("Resources.AppResources", "Kheper.Shared");
        LangService.OnLanguageChanged += HandleLanguageChanged;
    }

    private void HandleLanguageChanged()
    {
        L = LocalizerFactory.Create("Resources.AppResources", "Kheper.Shared");
        InvokeAsync(StateHasChanged);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            email = await LocalStorage.GetItemAsync<string>("userEmail") ?? string.Empty;
            emailPassword = await LocalStorage.GetItemAsync<string>("userPassword") ?? string.Empty;

            var savedTasks = await LocalStorage.GetItemAsync<List<TodoTask>>("tasks");
            if (savedTasks != null) tasks = savedTasks;

            var savedPackages = await LocalStorage.GetItemAsync<List<Package>>("packages");  // ← added
            if (savedPackages != null) packages = savedPackages;                             // ← added

            StateHasChanged();
        }
    }

    private async Task HandleLogin()
    {
        await SendRequest("api/AccountAPI/login", "התחברת בהצלחה!");
    }

    private async Task HandleRegister()
    {
        await SendRequest("api/AccountAPI/register", "נרשמת בהצלחה! עכשיו אפשר להתחבר.");
    }

    private async Task SendRequest(string endpoint, string successText)
    {
        try
        {
            statusMessage = "שולח בקשה...";
            var client = ClientFactory.CreateClient("LocalApi");

            // ← packages is now included in the request body
            var loginData = new
            {
                Username = username,
                Password = password,
                Email = email,
                EmailPassword = emailPassword,
                tasks = tasks,
                packages = packages
            };

            var response = await client.PostAsJsonAsync(endpoint, loginData);

            if (response.IsSuccessStatusCode)
            {
                statusMessage = successText;

                if (endpoint.Contains("login"))
                {
                    var result = await response.Content.ReadFromJsonAsync<LoginResponse>();
                    if (result != null)
                    {
                        if (!string.IsNullOrEmpty(result.Email))
                        {
                            await LocalStorage.SetItemAsync("userEmail", result.Email);
                            email = result.Email;
                        }
                        if (!string.IsNullOrEmpty(result.EmailPassword))
                        {
                            await LocalStorage.SetItemAsync("userPassword", result.EmailPassword);
                            emailPassword = result.EmailPassword;
                        }
                        if (result.Tasks != null)
                        {
                            tasks = result.Tasks;
                            await LocalStorage.SetItemAsync("tasks", tasks);
                        }
                        // ← save packages returned from server into LocalStorage
                        if (result.Packages != null)
                        {
                            packages = result.Packages;
                            await LocalStorage.SetItemAsync("packages", packages);
                        }
                    }
                }
            }
            else
            {
                var errorRaw = await response.Content.ReadAsStringAsync();
                if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
                    statusMessage = "שם משתמש או סיסמה שגויים (או שהמשתמש לא קיים).";
                else
                    statusMessage = $"שגיאה מהשרת: {errorRaw}";
            }
        }
        catch (Exception ex)
        {
            statusMessage = $"שגיאת תקשורת: {ex.Message}";
        }
    }

    public class LoginResponse
    {
        public string? Message { get; set; }
        public int UserId { get; set; }
        public string? Email { get; set; }
        public string? EmailPassword { get; set; }
        public List<TodoTask>? Tasks { get; set; }
        public List<Package>? Packages { get; set; }   // ← added
    }

    public void Dispose()
    {
        LangService.OnLanguageChanged -= HandleLanguageChanged;
        if (!NavManager.Uri.Contains("settings", StringComparison.OrdinalIgnoreCase))
            NavState.SetSettingsMode(false);
    }
}
